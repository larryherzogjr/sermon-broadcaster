# Sermon Broadcaster Configuration
# Copy this to .env and fill in your values

# Required: Your Anthropic API key (for sermon boundary detection)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# Transcription backend: "openai" (Whisper API, default/fallback),
# "local" (M1 mini mlx-whisper HTTP service), or "faster-whisper" (on-CPU).
TRANSCRIBE_BACKEND=openai

# Required if TRANSCRIBE_BACKEND=openai: Your OpenAI API key
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx

# Required if TRANSCRIBE_BACKEND=local: the mini's pfSense-reserved static IP.
# Use the IP, NOT whisper-mini.local (mDNS won't resolve from the Linux VM).
# WHISPER_LOCAL_URL=http://10.0.0.50:5005
# A ~75-min sermon is a 5-8 min synchronous call — keep this generous (seconds).
# WHISPER_LOCAL_TIMEOUT=600

# Legacy toggle, superseded by TRANSCRIBE_BACKEND (kept for back-compat):
# TRANSCRIBER=cloud

# Optional overrides
# CLAUDE_MODEL=claude-sonnet-4-20250514
# WHISPER_MODEL_SIZE=medium
# DEFAULT_TARGET_DURATION=27:18

# Feedback → GitHub issue submission
# GITHUB_REPO=larryherzogjr/sermon-broadcaster
# GITHUB_TOKEN=ghp_xxx        # fine-grained PAT, scoped to the repo, issues:write
# CLAUDE_MODEL_FEEDBACK=claude-opus-4-7
