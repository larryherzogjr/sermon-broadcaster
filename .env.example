# Sermon Broadcaster Configuration
# Copy this to .env and fill in your values

# Required: Your Anthropic API key (for sermon boundary detection)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# Transcription engine: "cloud" (OpenAI, fast) or "local" (faster-whisper, free)
TRANSCRIBER=cloud

# Required if TRANSCRIBER=cloud: Your OpenAI API key
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx

# Optional overrides
# CLAUDE_MODEL=claude-sonnet-4-20250514
# WHISPER_MODEL_SIZE=medium
# DEFAULT_TARGET_DURATION=27:18
